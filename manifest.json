{
  "manifest_version": 3,
  "name": "Quick Links",
  "description": "Save any URL with a custom name and open it in one click.",
  "version": "1.0.1",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "permissions": ["storage"]
}
